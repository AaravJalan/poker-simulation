{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd web && npm ci && npm run build && cd .. && mkdir -p public && cp -r web/dist/* public/",
  "rewrites": [
    { "source": "/api", "destination": "/api/[...path].py" },
    { "source": "/api/(.*)", "destination": "/api/[...path].py" },
    { "source": "/((?!api/|assets/|favicon|index\\.html).*)", "destination": "/index.html" }
  ]
}
